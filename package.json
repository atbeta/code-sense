{
  "name": "@code-sense/core",
  "version": "0.1.3",
  "description": "Config-driven code knowledge graph for Vue projects — tree-sitter AST parsing, MCP server for AI agents, Sigma.js visualization",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "code-sense": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/opencode-cc/code-sense.git"
  },
  "keywords": [
    "vue",
    "code-graph",
    "knowledge-graph",
    "mcp",
    "tree-sitter",
    "ast",
    "code-analysis",
    "electron",
    "cli",
    "ai-agent"
  ],
  "license": "MIT",
  "author": "CodeSense Contributors",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "index": "node dist/index.js index",
    "serve": "node dist/index.js serve",
    "view": "node dist/index.js view",
    "clean": "rm -rf dist *.tsbuildinfo",
    "rebuild": "pnpm clean && pnpm build",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --check 'src/**/*.ts'",
    "format:fix": "prettier --write 'src/**/*.ts'",
    "check": "pnpm lint && pnpm format && pnpm build",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@ladybugdb/core": "^0.16.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sigma/edge-curve": "^3.1.0",
    "commander": "^12.0.0",
    "fast-glob": "^3.3.0",
    "graphology": "^0.26.0",
    "graphology-communities-louvain": "^2.0.2",
    "graphology-layout-force": "^0.2.4",
    "graphology-layout-forceatlas2": "^0.10.1",
    "graphology-layout-noverlap": "^0.4.2",
    "sigma": "^3.0.3",
    "tree-sitter-wasms": "^0.1.0",
    "web-tree-sitter": "^0.24.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.18",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "prettier": "^3.8.3",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.59.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@ladybugdb/core"
    ]
  }
}
